# ============================================================
# SAFIE Tools — Variáveis de Ambiente de Produção
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no git
# ============================================================

# Ambiente
NODE_ENV=production

# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=eyJ...  # Chave pública — pode ser exposta no frontend via VITE_
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # SEGREDO — nunca expor. Usar apenas no backend.

# HubSpot
HUBSPOT_API_KEY=pat-na1-...  # Private App Token com escopos: contacts (read/write)
HUBSPOT_PORTAL_ID=12345678

# OAuth
OAUTH_REDIRECT_URL=https://ferramentas.safie.com.br/auth/callback
# Cadastrar esta URL também em:
# - Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client > Authorized redirect URIs
# - Supabase Dashboard > Authentication > URL Configuration > Redirect URLs

# Frontend
FRONTEND_URL=https://ferramentas.safie.com.br

# Servidor
PORT=3001
